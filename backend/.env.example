# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=your-secret-key-change-in-production
FLASK_DEBUG=True

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/transcoding_db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# AWS S3 (or MinIO for local dev)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=eu-west-1
S3_RAW_BUCKET=transcoding-raw-videos
S3_PROCESSED_BUCKET=transcoding-processed-videos

# CDN
CDN_BASE_URL=https://cdn.yourdomain.com

# FFmpeg
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# Upload limits
MAX_UPLOAD_SIZE_GB=10
ALLOWED_EXTENSIONS=mp4,mov,avi,mkv,wmv,flv,webm,m4v

# Workers
CELERY_WORKER_CONCURRENCY=4
TRANSCODING_TIMEOUT_SECONDS=3600
